---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  formatBlogDate,
  getBlogHrefFromTitle,
  type BlogBilingualContent,
} from '../lib/blog';
import { getBlogMarkdownProcessor } from '../lib/markdown';

interface Props {
  post: CollectionEntry<'blog'>;
  slug: string;
  title: string;
  content: BlogBilingualContent;
}

const { post, slug, title, content } = Astro.props as Props;

const enHasContent = content.enMarkdown.trim().length > 0;
const koHasContent = content.koMarkdown.trim().length > 0;
const defaultLang = enHasContent ? 'en' : koHasContent ? 'ko' : 'en';

const markdownProcessor = await getBlogMarkdownProcessor();
const enRendered = enHasContent
  ? await markdownProcessor.render(content.enMarkdown)
  : null;
const koRendered = koHasContent
  ? await markdownProcessor.render(content.koMarkdown)
  : null;

const postRelativeUrl = getBlogHrefFromTitle(title);
---

<BaseLayout title={`${title} - Blog - Yoonchul Yi`}>
  <article class="py-8">
    <a
      href="/blog"
      class="inline-block font-mono text-xs text-sub hover:text-accent transition-colors"
    >
      ← Back to blog
    </a>

    <header class="mt-4 mb-8 border-b border-sub/20 pb-6 flex flex-wrap items-start justify-between gap-4">
      <div class="min-w-0">
        <h1 class="font-serif text-2xl md:text-3xl text-text break-words">
          {title}
        </h1>
        <p class="mt-2 font-mono text-xs text-sub">
          {formatBlogDate(post.data.date)}
        </p>
      </div>

      <div class="flex items-center gap-4">
        <div
          role="group"
          aria-label="Language toggle"
          class="font-mono text-xs text-sub flex items-center gap-2"
        >
          <button
            id="blog-lang-en"
            type="button"
            class:list={[
              'blog-lang-button',
              { 'text-accent': defaultLang === 'en' },
            ]}
            data-lang="en"
            aria-pressed={defaultLang === 'en' ? 'true' : 'false'}
          >
            En
          </button>
          <span>/</span>
          <button
            id="blog-lang-ko"
            type="button"
            class:list={[
              'blog-lang-button',
              { 'text-accent': defaultLang === 'ko' },
            ]}
            data-lang="ko"
            aria-pressed={defaultLang === 'ko' ? 'true' : 'false'}
          >
            Ko
          </button>
        </div>

        <button
          id="copy-link-button"
          type="button"
          data-relative-url={postRelativeUrl}
          data-slug={slug}
          class="font-mono text-xs text-sub hover:text-accent transition-colors"
        >
          <span id="copy-link-label">Share</span>
        </button>
      </div>
    </header>

    <div
      class:list={[
        'blog-content font-serif text-base leading-relaxed text-text',
        { hidden: defaultLang !== 'en' },
      ]}
      data-lang-panel="en"
    >
      {
        enHasContent && enRendered ? (
          <div set:html={enRendered.code} />
        ) : (
          <div
            class="blog-empty-lang rounded-md border border-sub/25 bg-sub/5 px-5 py-6"
            role="status"
            aria-live="polite"
          >
            <p class="font-mono text-sm text-sub">
              English version is not available yet.
            </p>
            <p class="mt-2 font-mono text-xs text-sub/80">
              {
                koHasContent
                  ? 'Use the Ko toggle above to read this post in Korean.'
                  : 'Korean text is not available for this post either.'
              }
            </p>
          </div>
        )
      }
    </div>
    <div
      class:list={[
        'blog-content font-serif text-base leading-relaxed text-text',
        { hidden: defaultLang !== 'ko' },
      ]}
      data-lang-panel="ko"
    >
      {
        koHasContent && koRendered ? (
          <div set:html={koRendered.code} />
        ) : (
          <div
            class="blog-empty-lang rounded-md border border-sub/25 bg-sub/5 px-5 py-6"
            role="status"
            aria-live="polite"
          >
            <p class="font-mono text-sm text-sub">
              한국어 버전은 아직 준비 중입니다.
            </p>
            <p class="mt-2 font-mono text-xs text-sub/80">
              {
                enHasContent
                  ? '위에서 En을 눌러 영어 본문을 읽을 수 있습니다.'
                  : '영어 본문도 아직 없습니다.'
              }
            </p>
          </div>
        )
      }
    </div>
  </article>
</BaseLayout>

<script>
  const langEnButton = document.getElementById('blog-lang-en');
  const langKoButton = document.getElementById('blog-lang-ko');
  const panels = Array.from(document.querySelectorAll('[data-lang-panel]'));

  const setLanguage = (lang) => {
    panels.forEach((panel) => {
      panel.classList.toggle('hidden', panel.dataset.langPanel !== lang);
    });

    if (langEnButton && langKoButton) {
      const isEnglish = lang === 'en';
      langEnButton.setAttribute('aria-pressed', isEnglish ? 'true' : 'false');
      langKoButton.setAttribute('aria-pressed', isEnglish ? 'false' : 'true');
      langEnButton.classList.toggle('text-accent', isEnglish);
      langKoButton.classList.toggle('text-accent', !isEnglish);
    }
  };

  if (langEnButton && langKoButton) {
    langEnButton.addEventListener('click', () => setLanguage('en'));
    langKoButton.addEventListener('click', () => setLanguage('ko'));
  }

  const copyButton = document.getElementById('copy-link-button');
  const copyLabel = document.getElementById('copy-link-label');
  const copyFeedbackDurationMs = 1600;

  const copyFromFallback = (text) => {
    const input = document.createElement('textarea');
    input.value = text;
    input.setAttribute('readonly', '');
    input.style.position = 'absolute';
    input.style.left = '-9999px';
    document.body.appendChild(input);
    input.select();
    const copied = document.execCommand('copy');
    document.body.removeChild(input);
    return copied;
  };

  const copyToClipboard = async (text) => {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return true;
    }

    return copyFromFallback(text);
  };

  if (copyButton && copyLabel) {
    let resetLabelTimer;

    copyButton.addEventListener('click', async () => {
      const relativeUrl = copyButton.dataset.relativeUrl ?? window.location.pathname;
      const absoluteUrl = new URL(relativeUrl, window.location.origin).toString();
      const copied = await copyToClipboard(absoluteUrl).catch(() => false);

      copyLabel.textContent = copied ? 'Link copied' : 'Copy failed';

      clearTimeout(resetLabelTimer);
      resetLabelTimer = setTimeout(() => {
        copyLabel.textContent = 'Share';
      }, copyFeedbackDurationMs);
    });
  }
</script>

<style>
  :global(.blog-lang-button) {
    transition: color 0.2s ease;
  }

  :global(.blog-lang-button:hover) {
    color: #ea580c;
  }

  :global(.blog-content h2) {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-family: 'Newsreader', serif;
    font-size: 1.5rem;
    line-height: 1.25;
  }

  :global(.blog-content h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-family: 'Newsreader', serif;
    font-size: 1.25rem;
    line-height: 1.35;
  }

  :global(.blog-content p) {
    margin-bottom: 1rem;
  }

  :global(.blog-content a) {
    color: #ea580c;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  :global(.blog-content ul),
  :global(.blog-content ol) {
    margin: 1rem 0;
    padding-left: 1.25rem;
  }

  :global(.blog-content ul) {
    list-style: disc;
  }

  :global(.blog-content ol) {
    list-style: decimal;
  }

  :global(.blog-content li + li) {
    margin-top: 0.35rem;
  }

  :global(.blog-content hr) {
    margin: 1.25rem 0 0.5rem;
    border: 0;
    border-top: 1px solid rgba(140, 140, 140, 0.35);
  }

  :global(.blog-content hr + p) {
    margin-top: 0;
  }

  :global(.blog-content hr + ul),
  :global(.blog-content hr + ol) {
    margin-top: 0.5rem;
  }

  :global(.blog-content hr + section[data-footnotes]) {
    margin-top: 0.75rem;
  }

  :global(.blog-content section[data-footnotes]) {
    font-size: 0.875rem;
    line-height: 1.5;
    color: rgba(25, 25, 25, 0.82);
  }

  :global(.blog-content section[data-footnotes] ol) {
    margin: 0.5rem 0 0;
  }

  :global(.blog-content section[data-footnotes] p) {
    margin-bottom: 0.5rem;
  }

  :global(.blog-content sup) {
    font-size: 0.75em;
    line-height: 0;
  }

  :global(.blog-content blockquote) {
    margin: 1.25rem 0;
    padding-left: 0.9rem;
    border-left: 2px solid rgba(140, 140, 140, 0.35);
    color: rgba(25, 25, 25, 0.8);
  }

  :global(.blog-content code) {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.9em;
    background: rgba(140, 140, 140, 0.12);
    border-radius: 0.25rem;
    padding: 0.1rem 0.3rem;
  }
</style>
